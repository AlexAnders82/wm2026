---
// Header — DESIGN_SYSTEM.md 8.1. Logo + 4 Anker-Links, sticky, schlank.
// Kein Burger, kein CTA, keine Schatten.
import { href } from "../lib/paths.js";
import Logo from "./Logo.astro";
---

<header class="sticky top-0 z-30 bg-night/90 backdrop-blur border-b border-border">
  <div class="container-page h-14 flex items-center justify-between gap-4">
    <a href={href("")} aria-label="Anstoß '26 — Startseite" class="flex items-center">
      <Logo height={40} />
    </a>
    <nav class="flex items-center gap-3.5 text-sm text-text-secondary">
      <a href={href("#heute")} class="hover:text-text-primary">Heute</a>
      <a href={href("#spielplan")} class="hover:text-text-primary">Plan</a>
      <a href={href("#gruppen")} class="hover:text-text-primary">Gruppen</a>
      <a href={href("#tv-guide")} class="hover:text-text-primary">TV</a>
    </nav>
  </div>
</header>
