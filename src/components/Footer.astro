---
// Footer — DESIGN_SYSTEM.md 8.10: einspaltig, Recht + Vertrauen.
import { href } from "../lib/paths.js";
import { stampLabel } from "../lib/datetime.js";
import { updatedAt } from "../lib/data.js";
import Logo from "./Logo.astro";
---

<footer class="border-t border-border mt-[var(--space-section)]">
  <div class="container-read py-10 flex flex-col gap-4 text-text-secondary text-sm">
    <Logo height={44} />
    <p>Inoffizielle Fan-Seite. Kein Bezug zur FIFA. Alle Markennamen gehören ihren Eigentümern.</p>
    <nav class="flex flex-wrap gap-x-5 gap-y-2">
      <a href={href("impressum")} class="hover:text-text-primary">Impressum</a>
      <a href={href("datenschutz")} class="hover:text-text-primary">Datenschutz</a>
    </nav>
    <p class="text-xs">
      *Werbelink: Ein Abschluss kostet dich keinen Cent mehr, unterstützt aber diese Seite.
    </p>
    {updatedAt && (
      <p class="text-xs tabular">Datenstand: {stampLabel(updatedAt)} Uhr</p>
    )}
  </div>
</footer>
