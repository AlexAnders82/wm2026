---
// Logo — offizielles „Anstoß '26"-Badge (Spielerfigur + bunter WM-Ball + Wortmarke).
// Vom Nutzer geliefertes Artwork; ausdrücklicher Nutzerwunsch schlägt das reine
// Typo-Logo des Design-Systems. Quadratisch, daher width = height.
import { href } from "../lib/paths.js";
interface Props {
  height?: number;
  class?: string;
}
const { height = 30, class: cls = "" } = Astro.props;
---

<img
  src={href("anstoss26-logo-512.webp")}
  alt="Anstoß '26"
  width={height}
  height={height}
  class={cls}
  decoding="async"
/>
