---
// Logo — buntes Fußball-Logo "Anstoß '26" (auf ausdrücklichen Wunsch; weicht
// bewusst von DESIGN_SYSTEM.md 7 ab, das reine Typo vorsah). Inline-SVG,
// skaliert scharf. Ball mit farbigen Panels + Wortmarke.
interface Props {
  height?: number;
  class?: string;
}
const { height = 30, class: cls = "" } = Astro.props;
---

<svg
  class={cls}
  height={height}
  viewBox="0 0 212 48"
  role="img"
  aria-label="Anstoß '26"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- Ball -->
  <circle cx="24" cy="24" r="21" fill="#ffffff" stroke="#0B1120" stroke-width="2" />
  <!-- Nähte -->
  <g stroke="#0B1120" stroke-width="2" stroke-linecap="round">
    <line x1="24" y1="16" x2="24" y2="3" />
    <line x1="31.6" y1="21.5" x2="44" y2="17.5" />
    <line x1="28.7" y1="30.5" x2="36.3" y2="41" />
    <line x1="19.3" y1="30.5" x2="11.7" y2="41" />
    <line x1="16.4" y1="21.5" x2="4" y2="17.5" />
  </g>
  <!-- farbige Panels -->
  <polygon points="32,9.8 35.04,12.01 33.88,15.59 30.12,15.59 28.96,12.01" fill="#F0B429" />
  <polygon points="37,24.8 40.04,27.01 38.88,30.59 35.12,30.59 33.96,27.01" fill="#E20074" />
  <polygon points="24,34.8 27.04,37.01 25.88,40.59 22.12,40.59 20.96,37.01" fill="#2FCB6E" />
  <polygon points="11,24.8 14.04,27.01 12.88,30.59 9.12,30.59 7.96,27.01" fill="#3D6BE0" />
  <polygon points="16,9.8 19.04,12.01 17.88,15.59 14.12,15.59 12.96,12.01" fill="#F0B429" />
  <!-- zentrales Panel -->
  <polygon points="24,16 31.6,21.5 28.7,30.5 19.3,30.5 16.4,21.5" fill="#0B1120" />

  <!-- Wortmarke -->
  <text
    x="55"
    y="34"
    font-family="'Barlow Condensed','Arial Narrow',sans-serif"
    font-weight="700"
    font-size="31"
    letter-spacing="0.5"
  >
    <tspan fill="#EDF1F8">ANSTOSS</tspan><tspan fill="#2FCB6E"> '</tspan><tspan fill="#F0B429">26</tspan>
  </text>
</svg>
