---
// Goals — Torschützen eines Spiels. Heim links, Gast rechts. ET=Eigentor, FE=Elfmeter.
interface Props {
  goals: any[];
}
const { goals = [] } = Astro.props;
---

{goals.length > 0 && (
  <ul class="mt-2 grid grid-cols-2 gap-x-3 gap-y-0.5 text-xs text-text-secondary" data-role="goals">
    {goals.map((g) => (
      <li class={g.side === "away" ? "col-start-2 text-right" : "col-start-1"}>
        <span class="tabular text-text-primary">{g.minute}'</span> {g.scorer}{g.own ? " (ET)" : ""}{g.pen ? " (FE)" : ""}
      </li>
    ))}
  </ul>
)}
