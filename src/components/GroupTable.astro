---
// GroupTable — Gruppentabelle (aus Ergebnissen berechnet). Top 2 = Achtelfinale,
// plus beste Gruppendritte (deshalb Platz 3 dezent markiert).
import Flag from "./Flag.astro";

interface Props {
  group: { letter: string; standings: any[] };
  compact?: boolean;
}
const { group, compact = false } = Astro.props;
---

<div class="rounded-xl bg-card border border-border overflow-hidden">
  <div class="px-3 py-2 border-b border-border">
    <h3 class="font-display font-bold uppercase tracking-wide">Gruppe {group.letter}</h3>
  </div>
  <table class="w-full text-sm tabular">
    <thead>
      <tr class="text-text-secondary text-xs uppercase tracking-[0.08em]">
        <th class="text-left font-medium px-3 py-1.5 w-6">#</th>
        <th class="text-left font-medium py-1.5">Team</th>
        <th class="text-center font-medium px-1 py-1.5 w-7" title="Spiele">Sp</th>
        {!compact && <th class="text-center font-medium px-1 py-1.5 w-10" title="Tore">Tore</th>}
        <th class="text-center font-medium px-1 py-1.5 w-9" title="Tordifferenz">Diff</th>
        <th class="text-center font-semibold px-3 py-1.5 w-9" title="Punkte">Pkt</th>
      </tr>
    </thead>
    <tbody>
      {group.standings.map((r, i) => (
        <tr class={`border-t border-border ${i < 2 ? "bg-pitch/5" : ""}`}>
          <td class="px-3 py-2 text-text-secondary">
            <span class={i < 2 ? "text-pitch font-semibold" : i === 2 ? "text-gold" : ""}>{i + 1}</span>
          </td>
          <td class="py-2">
            <span class="flex items-center gap-2 min-w-0">
              <Flag code={r.code} name={r.team} size={18} />
              <span class="truncate text-text-primary">{r.team}</span>
            </span>
          </td>
          <td class="text-center px-1 text-text-secondary">{r.p}</td>
          {!compact && <td class="text-center px-1 text-text-secondary">{r.gf}:{r.ga}</td>}
          <td class="text-center px-1 text-text-secondary">{r.gd > 0 ? `+${r.gd}` : r.gd}</td>
          <td class="text-center px-3 font-display font-bold text-text-primary">{r.pts}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
