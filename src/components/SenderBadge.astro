---
// SenderBadge — DESIGN_SYSTEM.md 8.5. Pill in Senderfarbe, weißer Text.
// 'tbd' -> Outline-Pill "ARD/ZDF". link=false rendert eine Beschriftung statt
// eines <a> (wichtig in der MatchCard, die selbst ein Link ist -> keine
// verschachtelten Anker, sonst zerlegt der Browser die Karte).
import { linkFor } from "../lib/links.js";

interface Props {
  sender: string; // "ARD" | "ZDF" | "MagentaTV" | "tbd"
  link?: boolean;
}
const { sender, link = true } = Astro.props;

const COLORS = {
  ARD: "bg-ard",
  ZDF: "bg-zdf",
  MagentaTV: "bg-magenta",
};

const base =
  "inline-flex items-center h-6 px-2 rounded-full font-display font-semibold text-xs leading-none";
const colorClass = COLORS[sender] ?? "bg-pitchbox";
const entry = sender === "tbd" ? null : linkFor(sender);
const star = entry?.star ? "*" : "";
---

{sender === "tbd" ? (
  <span class={`${base} border border-border text-text-secondary`}>ARD/ZDF</span>
) : link && entry ? (
  <a
    href={entry.url}
    target="_blank"
    rel={entry.rel}
    class={`${base} ${colorClass} text-white`}
    aria-label={`${sender}${star ? " (Werbelink)" : ""} – zum Stream`}
  >
    {sender}{star}
  </a>
) : (
  <span class={`${base} ${colorClass} text-white`}>{sender}{star}</span>
)}
