---
// Startseite — Sektionen 1–3 (Header via Base, Hero/Matchday, Spielplan+Filter).
// Sektionen 4–7 (TV-Guide, Kalender, FAQ) folgen in Task 7.
import Base from "../layouts/Base.astro";
import MatchCard from "../components/MatchCard.astro";
import DayGroup from "../components/DayGroup.astro";
import Countdown from "../components/Countdown.astro";
import Flag from "../components/Flag.astro";
import { getMatches, groupByDay } from "../lib/data.js";
import { dayKey, fullDate } from "../lib/datetime.js";
import { href } from "../lib/paths.js";

const matches = getMatches();
const now = Date.now();
const todayKey = dayKey(new Date().toISOString());

// --- Hero-Logik (DS 8.2) ---
const live = matches.filter((m) => m.score?.status === "live");
const upcoming = matches.filter(
  (m) => m.kickoffUtc && new Date(m.kickoffUtc).getTime() >= now
);

let heroMatches, heroHeading;
if (live.length) {
  heroMatches = live;
  heroHeading = "Heute live";
} else if (upcoming.length) {
  const nextKey = dayKey(upcoming[0].kickoffUtc);
  heroMatches = upcoming.filter((m) => dayKey(m.kickoffUtc) === nextKey).slice(0, 4);
  heroHeading = nextKey === todayKey ? "Heute" : "Nächster Spieltag";
} else {
  heroMatches = [];
  heroHeading = "Spielplan";
}
const heroCaption = heroMatches.length ? fullDate(heroMatches[0].kickoffUtc) : "";
const nextDE = upcoming.find((m) => m.isDE);

// --- Spielplan ---
const groups = groupByDay(matches);
---

<Base
  title="Anstoß '26 — WM 2026 Spielplan, Ergebnisse & wo läuft's?"
  description="Alle 104 Spiele der WM 2026 mit deutschen Anstoßzeiten, Ergebnissen und Sender (ARD, ZDF, MagentaTV). Mobil, werbefrei, ohne Cookies."
>
  <!-- 2 · Hero "Matchday" -->
  <section id="heute" class="hero">
    <div class="container-read pt-8 pb-2">
      {heroCaption && (
        <p class="text-xs uppercase tracking-[0.08em] text-text-secondary">{heroCaption}</p>
      )}
      <h1 class="text-hero uppercase mt-1">{heroHeading}</h1>

      <div class="flex flex-col gap-[var(--space-card-gap)] mt-6">
        {heroMatches.map((m) => <MatchCard match={m} />)}
      </div>

      {nextDE && (
        <div class="mt-6 rounded-xl bg-card p-4" style="border:1px solid var(--color-gold)">
          <p class="flex items-center gap-2 text-xs uppercase tracking-[0.08em] text-text-secondary">
            <Flag code="de" name="Deutschland" size={18} /> Nächstes DE-Spiel
          </p>
          <a
            href={href(`spiel/${nextDE.slug}`)}
            class="flex items-baseline justify-between gap-3 mt-2 hover:opacity-90"
          >
            <Countdown target={nextDE.kickoffUtc} class="text-xl font-display font-bold text-gold" />
            <span class="text-sm text-text-secondary whitespace-nowrap">
              {nextDE.home.name} – {nextDE.away.name} →
            </span>
          </a>
        </div>
      )}
    </div>
  </section>

  <!-- 3 · Spielplan -->
  <section id="spielplan" class="section">
    <div class="container-read">
      <h2 class="text-2xl uppercase">Spielplan</h2>
      <p class="text-md text-text-secondary mt-2">
        Alle 104 Spiele, deutsche Anstoßzeiten, jeder Sender.
      </p>

      <div class="scroll-x flex gap-2 mt-6 -mx-4 px-4" role="group" aria-label="Spiele filtern">
        <button type="button" class="chip" data-filter="all" aria-pressed="true">Alle</button>
        <button type="button" class="chip inline-flex items-center gap-1.5" data-filter="de" aria-pressed="false">
          <Flag code="de" name="Deutschland" size={16} /> Deutschland
        </button>
        <button type="button" class="chip" data-filter="group" aria-pressed="false">Gruppenphase</button>
        <button type="button" class="chip" data-filter="ko" aria-pressed="false">K.o.-Runde</button>
      </div>

      <div id="spielplan-list">
        {groups.map((g) => <DayGroup group={g} isPast={g.key < todayKey} />)}
      </div>
    </div>
  </section>
</Base>

<script>
  // Spielplan-Filter (DS 6): Karten ein-/ausblenden, leere Tage verstecken.
  const chips = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-filter]"));
  const scope = document.getElementById("spielplan-list");

  function apply(filter: string) {
    if (!scope) return;
    scope.querySelectorAll<HTMLElement>("[data-match]").forEach((el) => {
      const isDE = el.getAttribute("data-de") === "true";
      const phase = el.getAttribute("data-phase");
      const show =
        filter === "all" ||
        (filter === "de" && isDE) ||
        (filter === "group" && phase === "group") ||
        (filter === "ko" && phase === "ko");
      el.toggleAttribute("hidden", !show);
    });
    scope.querySelectorAll<HTMLElement>("[data-day]").forEach((day) => {
      const visible = day.querySelectorAll("[data-match]:not([hidden])").length;
      day.toggleAttribute("hidden", visible === 0);
    });
  }

  chips.forEach((chip) => {
    chip.addEventListener("click", () => {
      chips.forEach((c) => c.setAttribute("aria-pressed", c === chip ? "true" : "false"));
      apply(chip.getAttribute("data-filter") || "all");
    });
  });
</script>
