---
// Startseite — Sektionen 1–3 (Header via Base, Hero/Matchday, Spielplan+Filter).
// Sektionen 4–7 (TV-Guide, Kalender, FAQ) folgen in Task 7.
import Base from "../layouts/Base.astro";
import MatchCard from "../components/MatchCard.astro";
import DayGroup from "../components/DayGroup.astro";
import GroupTable from "../components/GroupTable.astro";
import Countdown from "../components/Countdown.astro";
import Flag from "../components/Flag.astro";
import { getMatches, groupByDay, getGroups } from "../lib/data.js";
import { dayKey, fullDate } from "../lib/datetime.js";
import { href, absUrl } from "../lib/paths.js";
import { linkFor } from "../lib/links.js";

const site = Astro.site!;
const magenta = linkFor("MagentaTV");
const icsHttps = absUrl("wm2026.ics", site);
const icsWebcal = icsHttps.replace(/^https?:/, "webcal:");

// FAQ (DS 8.9) — echte Suchfragen, auch als FAQPage-JSON-LD (PLAN 6).
const faq = [
  { q: "Wo läuft das Finale der WM 2026?", a: "Das Finale am 19. Juli läuft im Free-TV im ZDF und zusätzlich bei MagentaTV." },
  { q: "Was kostet MagentaTV?", a: "Das MagentaTV-Flex-Abo kostet 11 € pro Monat und ist monatlich kündbar." },
  { q: "Welche Spiele laufen nicht im Free-TV?", a: "44 der 104 Spiele zeigt ausschließlich MagentaTV. Die übrigen 60 laufen bei ARD oder ZDF." },
  { q: "Wann spielt Deutschland?", a: "Sa 14.6. 19:00 gegen Curaçao (ARD), Sa 20.6. 22:00 gegen Elfenbeinküste (ZDF), Do 25.6. 22:00 gegen Ecuador (ARD). Alle Spiele auch bei MagentaTV." },
  { q: "In welcher Zeitzone stehen die Anstoßzeiten?", a: "Alle Zeiten auf dieser Seite sind deutsche Zeit (MESZ)." },
  { q: "Brauche ich für das Kalender-Abo eine App?", a: "Nein. Das Abo funktioniert mit dem Standard-Kalender auf iPhone und Android." },
  { q: "Kostet diese Seite etwas oder hat sie Werbung?", a: "Die Seite ist kostenlos, werbefrei und ohne Cookies. Einzelne Links sind mit * als Werbelink gekennzeichnet." },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Anstoß '26",
    url: absUrl("", site),
    inLanguage: "de",
    description: "Spielplan, Ergebnisse und Sender (ARD, ZDF, MagentaTV) aller 104 Spiele der WM 2026 mit deutschen Anstoßzeiten.",
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faq.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
  },
];

const matches = getMatches();
const now = Date.now();
const todayKey = dayKey(new Date().toISOString());

// --- Tagesübersicht: ALLE Spiele von heute (sonst nächster Spieltag) ---
const todayMatches = matches.filter((m) => m.kickoffUtc && dayKey(m.kickoffUtc) === todayKey);
let heroMatches, heroHeading;
if (todayMatches.length) {
  heroMatches = todayMatches;
  heroHeading = heroMatches.some((m) => m.state === "live") ? "Heute live" : "Heute";
} else {
  const future = matches.filter((m) => m.kickoffUtc && dayKey(m.kickoffUtc) > todayKey);
  const nextKey = future.length ? dayKey(future[0].kickoffUtc) : null;
  heroMatches = nextKey ? matches.filter((m) => m.kickoffUtc && dayKey(m.kickoffUtc) === nextKey) : [];
  heroHeading = nextKey ? "Nächster Spieltag" : "Spielplan";
}
const heroCaption = heroMatches.length ? fullDate(heroMatches[0].kickoffUtc) : "";
const upcoming = matches.filter((m) => m.kickoffUtc && new Date(m.kickoffUtc).getTime() >= now);
const nextDE = upcoming.find((m) => m.isDE);

// --- Spielplan ---
const groups = groupByDay(matches);

// --- Gruppen-Tabellen ---
const standings = getGroups();
---

<Base
  title="Anstoß '26 — WM 2026 Spielplan, Ergebnisse & wo läuft's?"
  description="Alle 104 Spiele der WM 2026 mit deutschen Anstoßzeiten, Ergebnissen und Sender (ARD, ZDF, MagentaTV). Mobil, werbefrei, ohne Cookies."
  jsonLd={jsonLd}
>
  <!-- 2 · Hero "Matchday" -->
  <section id="heute" class="hero">
    <div class="container-read pt-8 pb-2">
      {heroCaption && (
        <p class="text-xs uppercase tracking-[0.08em] text-text-secondary">{heroCaption}</p>
      )}
      <h1 class="text-hero uppercase mt-1">{heroHeading}</h1>

      <div class="flex flex-col gap-[var(--space-card-gap)] mt-6">
        {heroMatches.map((m) => <MatchCard match={m} showGoals={true} />)}
      </div>

      {nextDE && (
        <div class="mt-6 rounded-xl bg-card p-4" style="border:1px solid var(--color-gold)">
          <p class="flex items-center gap-2 text-xs uppercase tracking-[0.08em] text-text-secondary">
            <Flag code="de" name="Deutschland" size={18} /> Nächstes DE-Spiel
          </p>
          <a
            href={href(`spiel/${nextDE.slug}`)}
            class="flex items-baseline justify-between gap-3 mt-2 hover:opacity-90"
          >
            <Countdown target={nextDE.kickoffUtc} class="text-xl font-display font-bold text-gold" />
            <span class="text-sm text-text-secondary whitespace-nowrap">
              {nextDE.home.name} – {nextDE.away.name} →
            </span>
          </a>
        </div>
      )}
    </div>
  </section>

  <!-- 3 · Spielplan -->
  <section id="spielplan" class="section">
    <div class="container-read">
      <h2 class="text-2xl uppercase">Spielplan</h2>
      <p class="text-md text-text-secondary mt-2">
        Alle 104 Spiele, deutsche Anstoßzeiten, jeder Sender.
      </p>

      <div class="scroll-x flex gap-2 mt-6 -mx-4 px-4" role="group" aria-label="Spiele filtern">
        <button type="button" class="chip" data-filter="all" aria-pressed="true">Alle</button>
        <button type="button" class="chip inline-flex items-center gap-1.5" data-filter="de" aria-pressed="false">
          <Flag code="de" name="Deutschland" size={16} /> Deutschland
        </button>
        <button type="button" class="chip" data-filter="group" aria-pressed="false">Gruppenphase</button>
        <button type="button" class="chip" data-filter="ko" aria-pressed="false">K.o.-Runde</button>
      </div>

      <div id="spielplan-list">
        {groups.map((g) => <DayGroup group={g} isPast={g.key < todayKey} />)}
      </div>
    </div>
  </section>

  <!-- 3b · Gruppen-Tabellen -->
  {standings.length > 0 && (
    <section id="gruppen" class="section">
      <div class="container-read">
        <h2 class="text-2xl uppercase">Gruppen</h2>
        <p class="text-md text-text-secondary mt-2">
          Tabelle nach jedem Spiel automatisch aktualisiert. Die ersten Zwei jeder Gruppe sind im
          Achtelfinale, dazu die acht besten Gruppendritten.
        </p>
        <div class="grid gap-3 mt-6 sm:grid-cols-2">
          {standings.map((g) => <GroupTable group={g} />)}
        </div>
      </div>
    </section>
  )}

  <!-- 4 · TV-Guide + MagentaTV-CTA (DS 8.6) -->
  <section id="tv-guide" class="section">
    <div class="container-read">
      <h2 class="text-2xl uppercase">Wo läuft die WM?</h2>
      <p class="text-md text-text-secondary mt-2">
        <span class="font-display text-text-primary">60</span> Spiele laufen im Free-TV bei
        ARD oder ZDF. <span class="font-display text-text-primary">44</span> Spiele zeigt nur
        MagentaTV. Alle <span class="font-display text-text-primary">104</span> Spiele gibt es
        bei MagentaTV.
      </p>

      <div class="mt-6 rounded-xl bg-card p-5" style="border:1px solid var(--color-magenta)">
        <h3 class="text-xl">44 Spiele laufen nur bei MagentaTV</h3>
        <p class="text-sm text-text-secondary mt-1">Flex-Abo · 11 €/Monat · monatlich kündbar</p>
        {magenta && (
          <a
            href={magenta.url}
            target="_blank"
            rel={magenta.rel}
            class="btn btn-magenta mt-4"
          >
            Zum Angebot{magenta.star ? "*" : ""}
          </a>
        )}
      </div>
    </div>
  </section>

  <!-- 5 · Kalender (DS 8.7) -->
  <section id="kalender" class="section">
    <div class="container-read">
      <h2 class="text-2xl uppercase">Alle Spiele in deinem Kalender</h2>
      <p class="text-md text-text-secondary mt-2">
        Einmal abonnieren — jedes Spiel steht in deinem Kalender, Ergebnisse inklusive.
      </p>

      <div class="flex flex-wrap gap-3 mt-5">
        <a href={icsWebcal} class="btn btn-pitch">📅 Kalender abonnieren</a>
        <button type="button" class="btn btn-outline" id="copy-ics" data-ics={icsHttps}>
          Link kopieren
        </button>
      </div>

      <div class="mt-5 flex flex-col gap-2">
        <details class="rounded-xl bg-card p-4">
          <summary class="cursor-pointer font-display font-semibold">iPhone</summary>
          <ol class="text-sm text-text-secondary mt-2 list-decimal pl-5 space-y-1">
            <li>Auf „Kalender abonnieren" tippen.</li>
            <li>Im Hinweis „Abonnieren" und dann „Fertig" bestätigen.</li>
          </ol>
        </details>
        <details class="rounded-xl bg-card p-4">
          <summary class="cursor-pointer font-display font-semibold">Android</summary>
          <ol class="text-sm text-text-secondary mt-2 list-decimal pl-5 space-y-1">
            <li>Auf „Link kopieren" tippen.</li>
            <li>In Google Kalender (Web) unter „Weitere Kalender → Per URL" einfügen.</li>
          </ol>
        </details>
      </div>
    </div>
  </section>

  <!-- 6 · FAQ (DS 8.9) -->
  <section id="faq" class="section">
    <div class="container-read">
      <h2 class="text-2xl uppercase">Häufige Fragen</h2>
      <div class="mt-5 flex flex-col gap-2">
        {faq.map((f) => (
          <details class="rounded-xl bg-card p-4">
            <summary class="cursor-pointer font-display font-semibold">{f.q}</summary>
            <p class="text-sm text-text-secondary mt-2">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <div class="toast" id="toast" role="status" aria-live="polite"></div>
</Base>

<script>
  // Spielplan-Filter (DS 6) + Kalender-Kopieren. Init bei jedem astro:page-load.
  function initHome() {
  const chips = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-filter]"));
  const scope = document.getElementById("spielplan-list");

  function apply(filter: string) {
    if (!scope) return;
    scope.querySelectorAll<HTMLElement>("[data-match]").forEach((el) => {
      const isDE = el.getAttribute("data-de") === "true";
      const phase = el.getAttribute("data-phase");
      const show =
        filter === "all" ||
        (filter === "de" && isDE) ||
        (filter === "group" && phase === "group") ||
        (filter === "ko" && phase === "ko");
      el.toggleAttribute("hidden", !show);
    });
    scope.querySelectorAll<HTMLElement>("[data-day]").forEach((day) => {
      const visible = day.querySelectorAll("[data-match]:not([hidden])").length;
      day.toggleAttribute("hidden", visible === 0);
    });
  }

  chips.forEach((chip) => {
    chip.addEventListener("click", () => {
      chips.forEach((c) => c.setAttribute("aria-pressed", c === chip ? "true" : "false"));
      apply(chip.getAttribute("data-filter") || "all");
    });
  });

  // Kalender-Link kopieren + Toast (DS 8.7)
  const copyBtn = document.getElementById("copy-ics");
  const toast = document.getElementById("toast");
  let toastTimer: ReturnType<typeof setTimeout> | undefined;

  function showToast(msg: string) {
    if (!toast) return;
    toast.textContent = msg;
    toast.classList.add("is-visible");
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => toast.classList.remove("is-visible"), 2600);
  }

  copyBtn?.addEventListener("click", async () => {
    const url = copyBtn.getAttribute("data-ics") || "";
    try {
      await navigator.clipboard.writeText(url);
      showToast("Kopiert — ab in die WhatsApp-Gruppe");
    } catch {
      showToast(url);
    }
  });
  }
  initHome();
</script>
