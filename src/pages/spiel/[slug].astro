---
// Spielseite — 104× programmatisch (DESIGN_SYSTEM.md 8.8, PLAN.md 4.2).
// Long-tail-SEO-Lander: eine Frage, eine Antwort. SportsEvent + BroadcastEvent.
import Base from "../../layouts/Base.astro";
import Flag from "../../components/Flag.astro";
import SenderBadge from "../../components/SenderBadge.astro";
import MatchCard from "../../components/MatchCard.astro";
import GroupTable from "../../components/GroupTable.astro";
import Lineups from "../../components/Lineups.astro";
import Goals from "../../components/Goals.astro";
import { getMatches, sameDayMatches, getGroup } from "../../lib/data.js";
import { dateTimeLabel, shortDate, timeLabel } from "../../lib/datetime.js";
import { href, absUrl } from "../../lib/paths.js";
import { matchCity } from "../../lib/venues.mjs";

export function getStaticPaths() {
  return getMatches().map((match) => ({
    params: { slug: match.slug },
    props: { match },
  }));
}

const { match } = Astro.props;
const site = Astro.site!;
const home = match.home?.name ?? "";
const away = match.away?.name ?? "";
const matchName = `${home} – ${away}`;

const freeSender = match.tv?.free && match.tv.free !== "none" ? match.tv.free : null;
const hasMagenta = (match.tv?.stream ?? []).includes("MagentaTV");
const senders = [
  ...(freeSender && freeSender !== "tbd" ? [freeSender] : []),
  ...(hasMagenta ? ["MagentaTV"] : []),
];
const hasScore = match.score?.home != null && match.score?.away != null;

// SEO (PLAN 4.2 / DS 10)
const title = `${matchName} live: Übertragung, Anstoßzeit & Ergebnis | WM 2026`;
const senderPhrase = freeSender && freeSender !== "tbd" ? `im ${freeSender}` : "bei MagentaTV";
const description = `${matchName} am ${shortDate(match.kickoffUtc)} um ${timeLabel(match.kickoffUtc)} Uhr: Übertragung live ${senderPhrase}. Anstoßzeit, Stadion & Ergebnis.`;
const canonical = absUrl(`spiel/${match.slug}`, site);

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "SportsEvent",
    name: matchName,
    sport: "Soccer",
    startDate: match.kickoffUtc,
    url: canonical,
    eventStatus:
      match.score?.status === "finished"
        ? "https://schema.org/EventScheduled"
        : "https://schema.org/EventScheduled",
    homeTeam: { "@type": "SportsTeam", name: home },
    awayTeam: { "@type": "SportsTeam", name: away },
    ...(match.venue?.stadium || match.venue?.city
      ? {
          location: {
            "@type": "Place",
            name: match.venue?.stadium || match.venue?.city,
            address: [match.venue?.city, match.venue?.country].filter(Boolean).join(", "),
          },
        }
      : {}),
  },
  ...(senders.length
    ? [
        {
          "@context": "https://schema.org",
          "@type": "BroadcastEvent",
          name: `${matchName} live`,
          isLiveBroadcast: true,
          startDate: match.kickoffUtc,
          publishedOn: senders.map((s) => ({ "@type": "BroadcastService", name: s })),
        },
      ]
    : []),
];

const others = sameDayMatches(match, 3);
const group = match.group ? getGroup(match.group) : null;
const phaseLabel = match.group
  ? `Gruppe ${match.group}${match.matchday ? ` · Spieltag ${match.matchday}` : ""}`
  : match.round || "";
const venueLabel = [match.venue?.stadium, match.venue?.city].filter(Boolean).join(", ");
const venueTz = matchCity(match.venue?.stadium || match.venue?.city || "")?.tz || null;

const state = match.state ?? "scheduled";
const showScore = state === "live" || state === "finished";

// Letzte 3 Ergebnisse je Team (Form), aus Sicht des jeweiligen Teams.
const all = getMatches();
function formFor(code) {
  if (!code) return [];
  return all
    .filter((m) => m.state === "finished" && m.score?.home != null && (m.home?.code === code || m.away?.code === code))
    .sort((a, b) => b.kickoffUtc.localeCompare(a.kickoffUtc))
    .slice(0, 3)
    .map((m) => {
      const isHome = m.home?.code === code;
      const gf = isHome ? m.score.home : m.score.away;
      const ga = isHome ? m.score.away : m.score.home;
      const opp = isHome ? m.away : m.home;
      return { r: gf > ga ? "S" : gf < ga ? "N" : "U", gf, ga, opp: opp?.name ?? "" };
    });
}
const homeForm = formFor(match.home?.code);
const awayForm = formFor(match.away?.code);
const rColor = (r) => (r === "S" ? "text-pitch" : r === "N" ? "text-magenta" : "text-text-secondary");
---

<Base title={title} description={description} jsonLd={jsonLd} ogType="article">
  <div class="container-read section" data-oldb-id={match.oldbId ?? ""} data-state={state}>
    <!-- Breadcrumb -->
    <nav class="text-xs uppercase tracking-[0.08em] text-text-secondary" aria-label="Brotkrumen">
      <a href={href("#spielplan")} class="hover:text-text-primary">Spielplan</a>
      <span aria-hidden="true"> › </span>
      <span>{matchName}</span>
    </nav>

    <h1 class="text-2xl uppercase mt-3">{matchName}</h1>

    <!-- Live-/Beendet-Status -->
    <p class="mt-1" data-role="status">
      {state === "live" && (
        <span class="inline-flex items-center gap-1.5 text-pitch text-sm font-semibold"><span class="live-dot"></span>LIVE</span>
      )}
      {state === "finished" && (
        <span class="text-text-secondary text-xs font-semibold uppercase tracking-wide">Beendet</span>
      )}
    </p>

    <!-- Teams -->
    <div class="mt-4 flex flex-col gap-2">
      <div class="flex items-center gap-3">
        <Flag code={match.home?.code} name={home} size={28} />
        <span class="text-md text-text-primary">{home}</span>
        <span class="ml-auto font-display tabular text-xl font-bold" data-role="score-home">{showScore && match.score?.home != null ? match.score.home : ""}</span>
      </div>
      <div class="flex items-center gap-3">
        <Flag code={match.away?.code} name={away} size={28} />
        <span class="text-md text-text-primary">{away}</span>
        <span class="ml-auto font-display tabular text-xl font-bold" data-role="score-away">{showScore && match.score?.away != null ? match.score.away : ""}</span>
      </div>
    </div>

    <!-- Torschützen -->
    <div data-role="goals"><Goals goals={match.goals} /></div>

    <!-- Anstoß -->
    <div class="mt-6">
      <p class="text-xs uppercase tracking-[0.08em] text-text-secondary">Anstoß</p>
      <p class={`font-display tabular text-xl mt-1 ${match.isDE ? "text-gold" : "text-text-primary"}`}>
        {dateTimeLabel(match.kickoffUtc)}
      </p>
    </div>

    <!-- Sender -->
    <div class="mt-6">
      <p class="text-xs uppercase tracking-[0.08em] text-text-secondary mb-2">Übertragung</p>
      <div class="flex flex-wrap items-center gap-2">
        {freeSender && <SenderBadge sender={freeSender} />}
        {hasMagenta && <SenderBadge sender="MagentaTV" />}
        {!senders.length && <span class="text-sm text-text-secondary">Sender wird noch bekanntgegeben.</span>}
      </div>
      {match.isExclusive && hasMagenta && (
        <p class="text-magenta text-xs font-medium mt-2">Nur bei MagentaTV</p>
      )}
    </div>

    <!-- Eckdaten -->
    {(phaseLabel || venueLabel) && (
      <dl class="mt-6 text-sm">
        {phaseLabel && (
          <div class="flex gap-2 py-1 border-t border-border">
            <dt class="w-24 text-text-secondary uppercase text-xs tracking-[0.08em] pt-0.5">Runde</dt>
            <dd class="text-text-primary">{phaseLabel}</dd>
          </div>
        )}
        {venueLabel && (
          <div class="flex gap-2 py-1 border-t border-border">
            <dt class="w-24 text-text-secondary uppercase text-xs tracking-[0.08em] pt-0.5">Ort</dt>
            <dd class="text-text-primary">{venueLabel}</dd>
          </div>
        )}
        {match.weather && (
          <div class="flex gap-2 py-1 border-t border-border">
            <dt class="w-24 text-text-secondary uppercase text-xs tracking-[0.08em] pt-0.5">Wetter</dt>
            <dd class="text-text-primary tabular">{match.weather.tempC}°C · {match.weather.text}</dd>
          </div>
        )}
        {venueTz && (
          <div class="flex gap-2 py-1 border-t border-border">
            <dt class="w-24 text-text-secondary uppercase text-xs tracking-[0.08em] pt-0.5">Ortszeit</dt>
            <dd class="text-text-primary tabular" data-localclock data-tz={venueTz}>–</dd>
          </div>
        )}
      </dl>
    )}

    <!-- Aktuelle Form (letzte 3 Spiele) -->
    {(homeForm.length > 0 || awayForm.length > 0) && (
      <section class="mt-8">
        <h2 class="text-lg uppercase mb-3">Aktuelle Form</h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {[{ name: home, code: match.home?.code, form: homeForm }, { name: away, code: match.away?.code, form: awayForm }].map((t) => (
            <div class="rounded-xl bg-card border border-border p-4">
              <div class="flex items-center gap-2">
                <Flag code={t.code} name={t.name} size={18} />
                <span class="font-display font-bold text-text-primary">{t.name}</span>
              </div>
              {t.form.length > 0 ? (
                <ul class="mt-2 flex flex-col gap-1 text-sm">
                  {t.form.map((f) => (
                    <li class="flex items-center gap-2">
                      <span class={`font-display font-bold w-4 ${rColor(f.r)}`}>{f.r}</span>
                      <span class="tabular text-text-secondary">{f.gf}:{f.ga}</span>
                      <span class="text-text-secondary truncate">{f.opp}</span>
                    </li>
                  ))}
                </ul>
              ) : (
                <p class="text-sm text-text-secondary mt-2">Noch keine Spiele.</p>
              )}
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- MagentaTV-CTA nur bei Exklusivspielen (DS 8.8) -->
    {match.isExclusive && hasMagenta && (
      <div class="mt-6 rounded-xl bg-card p-5" style="border:1px solid var(--color-magenta)">
        <h2 class="text-lg">Dieses Spiel läuft nur bei MagentaTV</h2>
        <p class="text-sm text-text-secondary mt-1">Flex-Abo · 11 €/Monat · monatlich kündbar</p>
      </div>
    )}

    <!-- Aufstellungen -->
    <Lineups match={match} />

    <!-- Gruppentabelle -->
    {group && (
      <section class="mt-10">
        <h2 class="text-lg uppercase mb-3">Tabelle Gruppe {group.letter}</h2>
        <GroupTable group={group} />
      </section>
    )}

    {others.length > 0 && (
      <section class="mt-10">
        <h2 class="text-lg uppercase">Weitere Spiele an diesem Tag</h2>
        <div class="flex flex-col gap-[var(--space-card-gap)] mt-3">
          {others.map((m) => <MatchCard match={m} />)}
        </div>
      </section>
    )}

    <p class="mt-10">
      <a href={href("#spielplan")} class="text-pitch">← Zum Spielplan</a>
    </p>
  </div>

  <script>
    // Aktuelle Ortszeit am Spielort, sekündlich.
    function tickClock() {
      document.querySelectorAll<HTMLElement>("[data-localclock]").forEach((el) => {
        const tz = el.dataset.tz;
        if (!tz) return;
        try {
          el.textContent = new Intl.DateTimeFormat("de-DE", { timeZone: tz, hour: "2-digit", minute: "2-digit", second: "2-digit", hour12: false }).format(new Date()) + " Uhr";
        } catch {}
      });
    }
    tickClock();
    setInterval(tickClock, 1000);
  </script>
</Base>
