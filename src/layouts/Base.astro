---
// Base.astro — gemeinsames Gerüst aller Seiten.
// Meta/OG/Canonical, self-hosted Fonts (DSGVO, kein Google-CDN), Skip-Link,
// JSON-LD-Slot, Footer. Header kommt aus Task 6.
import "../styles/app.css";

// Self-hosted Schriften (DESIGN_SYSTEM.md 4) — nur benötigte Gewichte.
import "@fontsource/barlow/400.css";
import "@fontsource/barlow/500.css";
import "@fontsource/barlow/600.css";
import "@fontsource/barlow-condensed/600.css";
import "@fontsource/barlow-condensed/700.css";

// SVG-Flaggen self-hosted (flag-icons, MIT) — DESIGN_SYSTEM.md 7.
import "flag-icons/css/flag-icons.min.css";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { absUrl, href } from "../lib/paths.js";
import { liveSource } from "../lib/data.js";

interface Props {
  title: string;
  description: string;
  jsonLd?: object | object[];
  ogType?: string;
}

const { title, description, jsonLd, ogType = "website" } = Astro.props;
const site = Astro.site!;
const canonical = new URL(Astro.url.pathname, site).toString();
const ogImage = absUrl("og.png", site);
const ldBlocks = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0B1120" />
    <!-- Progressive Enhancement: markiert JS-Verfügbarkeit, bevor gerendert wird -->
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Favicon / App-Icons (Logo-Paket „Anstoß '26") -->
    <link rel="icon" href={href("favicon.ico")} sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href={href("favicon-32.png")} />
    <link rel="icon" type="image/png" sizes="16x16" href={href("favicon-16.png")} />
    <link rel="apple-touch-icon" href={href("apple-touch-icon.png")} />
    <link rel="manifest" href={href("site.webmanifest")} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="Anstoß '26" />
    <meta name="twitter:card" content="summary_large_image" />

    {ldBlocks.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}
  </head>
  <body data-oldb-source={liveSource ? `${liveSource.shortcut}|${liveSource.season}` : ""}>
    <a href="#main" class="skip-link">Zum Inhalt springen</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // Scroll-Reveal (DS 13, Motion #2) — IntersectionObserver, einmalig, gestaffelt.
      function initReveal() {
        const els = document.querySelectorAll<HTMLElement>(".reveal:not(.is-in)");
        if (!els.length) return;
        const io = new IntersectionObserver(
          (entries, obs) => {
            for (const e of entries) {
              if (!e.isIntersecting) continue;
              const el = e.target as HTMLElement;
              const siblings = el.parentElement ? Array.from(el.parentElement.children) : [];
              const i = Math.max(0, siblings.indexOf(el));
              el.style.transitionDelay = Math.min(i * 60, 300) + "ms";
              el.classList.add("is-in");
              obs.unobserve(el);
            }
          },
          { rootMargin: "0px 0px -10% 0px" }
        );
        els.forEach((el) => io.observe(el));
      }
      initReveal();
    </script>

    <script>
      // Live-Updates direkt im Browser: holt Ergebnisse + Tore von OpenLigaDB
      // (kein Warten auf den Build). Aktualisiert Karten/Spielseiten mit data-oldb-id.
      const src = document.body.dataset.oldbSource || "";
      if (src && document.querySelector("[data-oldb-id]")) {
        const [shortcut, season] = src.split("|");
        const url = `https://api.openligadb.de/getmatchdata/${shortcut}/${season}`;

        function goalsHtml(goals: any[]) {
          let p1 = 0, p2 = 0;
          const items: string[] = [];
          for (const g of (goals || []).slice().sort((a, b) => (a.matchMinute || 0) - (b.matchMinute || 0))) {
            const s1 = g.scoreTeam1 ?? p1, s2 = g.scoreTeam2 ?? p2;
            const side = s1 > p1 ? "home" : s2 > p2 ? "away" : "";
            p1 = s1; p2 = s2;
            if (!g.goalGetterName) continue;
            const cls = side === "away" ? "col-start-2 text-right" : "col-start-1";
            items.push(`<li class="${cls}"><span class="tabular text-text-primary">${g.matchMinute}'</span> ${g.goalGetterName}${g.isOwnGoal ? " (ET)" : ""}${g.isPenalty ? " (FE)" : ""}</li>`);
          }
          return items.length ? `<ul class="mt-2 grid grid-cols-2 gap-x-3 gap-y-0.5 text-xs text-text-secondary">${items.join("")}</ul>` : "";
        }

        async function poll() {
          let data;
          try {
            const r = await fetch(url, { cache: "no-store" });
            if (!r.ok) return false;
            data = await r.json();
          } catch { return false; }
          const byId = new Map((data || []).map((m: any) => [String(m.matchID), m]));
          let anyLive = false;
          document.querySelectorAll<HTMLElement>("[data-oldb-id]").forEach((card) => {
            const id = card.getAttribute("data-oldb-id");
            if (!id) return;
            const m: any = byId.get(id);
            if (!m) return;
            const res = (m.matchResults || []).slice().sort((a: any, b: any) => (b.resultTypeID || 0) - (a.resultTypeID || 0))[0];
            const ko = new Date(m.matchDateTimeUTC).getTime();
            const now = Date.now();
            const finished = !!m.matchIsFinished;
            const live = !finished && now >= ko && now < ko + 150 * 60000;
            const state = finished ? "finished" : live ? "live" : "scheduled";
            const sh = res ? res.pointsTeam1 : null, sa = res ? res.pointsTeam2 : null;
            const eh = card.querySelector('[data-role="score-home"]');
            const ea = card.querySelector('[data-role="score-away"]');
            if (eh && sh != null) eh.textContent = String(sh);
            if (ea && sa != null) ea.textContent = String(sa);
            const st = card.querySelector('[data-role="status"]');
            if (st) {
              if (state === "live") { st.innerHTML = '<span class="flex items-center justify-center gap-1.5 text-pitch text-sm font-semibold"><span class="live-dot"></span>LIVE</span>'; anyLive = true; }
              else if (state === "finished") { st.innerHTML = '<span class="text-text-secondary text-xs font-semibold uppercase tracking-wide">Beendet</span>'; }
            }
            card.setAttribute("data-state", state);
            if (state === "finished") card.classList.add("match-card--finished");
            const gc = card.querySelector('[data-role="goals"]');
            if (gc) gc.innerHTML = goalsHtml(m.goals);
          });
          return anyLive;
        }
        poll().then((live) => setInterval(poll, live ? 45000 : 120000));
      }
    </script>
  </body>
</html>
