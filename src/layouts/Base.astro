---
// Base.astro — gemeinsames Gerüst aller Seiten.
// Meta/OG/Canonical, self-hosted Fonts (DSGVO, kein Google-CDN), Skip-Link,
// JSON-LD-Slot, Footer. Header kommt aus Task 6.
import "../styles/app.css";

// Self-hosted Schriften (DESIGN_SYSTEM.md 4) — nur benötigte Gewichte.
import "@fontsource/barlow/400.css";
import "@fontsource/barlow/500.css";
import "@fontsource/barlow/600.css";
import "@fontsource/barlow-condensed/600.css";
import "@fontsource/barlow-condensed/700.css";

// SVG-Flaggen self-hosted (flag-icons, MIT) — DESIGN_SYSTEM.md 7.
import "flag-icons/css/flag-icons.min.css";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { absUrl } from "../lib/paths.js";

interface Props {
  title: string;
  description: string;
  jsonLd?: object | object[];
  ogType?: string;
}

const { title, description, jsonLd, ogType = "website" } = Astro.props;
const site = Astro.site!;
const canonical = new URL(Astro.url.pathname, site).toString();
const ogImage = absUrl("og.png", site);
const ldBlocks = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0B1120" />
    <!-- Progressive Enhancement: markiert JS-Verfügbarkeit, bevor gerendert wird -->
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="Anstoß '26" />
    <meta name="twitter:card" content="summary_large_image" />

    {ldBlocks.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}
  </head>
  <body>
    <a href="#main" class="skip-link">Zum Inhalt springen</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // Scroll-Reveal (DS 13, Motion #2) — IntersectionObserver, einmalig, gestaffelt.
      function initReveal() {
        const els = document.querySelectorAll<HTMLElement>(".reveal:not(.is-in)");
        if (!els.length) return;
        const io = new IntersectionObserver(
          (entries, obs) => {
            for (const e of entries) {
              if (!e.isIntersecting) continue;
              const el = e.target as HTMLElement;
              const siblings = el.parentElement ? Array.from(el.parentElement.children) : [];
              const i = Math.max(0, siblings.indexOf(el));
              el.style.transitionDelay = Math.min(i * 60, 300) + "ms";
              el.classList.add("is-in");
              obs.unobserve(el);
            }
          },
          { rootMargin: "0px 0px -10% 0px" }
        );
        els.forEach((el) => io.observe(el));
      }
      initReveal();
    </script>
  </body>
</html>
